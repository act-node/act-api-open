{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "telemetry.json",
  "title": "SensorTelemetry",
  "description": "30秒間隔の定期センサーデータ。QoS 0 のため欠損の可能性あり",
  "type": "object",
  "required": ["device_id","timestamp","sensors","sampled_at"],
  "properties": {
    "device_id":  { "type": "string", "example": "x320-curtain-01" },
    "timestamp":  { "type": "number", "description": "Unix epoch 秒" },
    "sensors": {
      "type": "object",
      "properties": {
        "temperature": {
          "type": "object",
          "required": ["value_celsius","raw_value","read_at"],
          "properties": {
            "value_celsius": {
              "type": "number",
              "minimum": -40,
              "maximum": 85,
              "description": "AD変換後の温度（℃）",
              "example": 28.4
            },
            "raw_value": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4095,
              "description": "AD変換生データ（12bit）。0/4095 は断線・短絡を示す可能性あり",
              "example": 2150
            },
            "read_at": {
              "type": "number",
              "description": "センサー読取時刻（Unix epoch 秒）",
              "example": 1710299998.5
            }
          }
        },
        "humidity_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "相対湿度（%）",
          "example": 71.2
        },
        "co2_ppm": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000,
          "description": "CO2濃度（ppm）。CO2センサーデバイスのみ",
          "example": 850
        }
      }
    },
    "sampled_at": {
      "type": "string",
      "format": "date-time",
      "description": "MQTT 送信時刻（ISO 8601 / UTC）。read_at との差で送信遅延を検知できる",
      "example": "2025-03-20T09:15:00Z"
    }
  }
}
