{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "command.json",
  "title": "CurtainCommand",
  "description": "Event Router から Control Logic へのモーター制御コマンド",
  "type": "object",
  "required": ["command_id", "issued_at", "source", "motors", "options"],
  "properties": {
    "command_id": {
      "type": "string",
      "description": "コマンドの一意識別子。response との照合に使用",
      "example": "cmd-abc123"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "コマンド発行時刻（ISO 8601 / UTC）",
      "example": "2025-03-20T09:15:00Z"
    },
    "source": {
      "type": "string",
      "description": "コマンド発行元の種別",
      "enum": [
        "event:motor_state",
        "event:limiter",
        "event:emergency_stop",
        "zone_transition",
        "timer",
        "manual",
        "shadow_delta",
        "timeout_retry"
      ],
      "example": "zone_transition"
    },
    "zone_id": {
      "type": ["string", "null"],
      "description": "コマンド発行時のアクティブゾーンID。手動操作時は null",
      "example": "daytime_auto"
    },
    "motors": {
      "type": "object",
      "description": "モーターごとの指示。キーは M1 または M2",
      "properties": {
        "M1": { "$ref": "#/definitions/MotorCommand" },
        "M2": { "$ref": "#/definitions/MotorCommand" }
      },
      "additionalProperties": false
    },
    "options": {
      "type": "object",
      "description": "モーター動作オプション",
      "required": ["cooldown_sec"],
      "properties": {
        "stop_before_reverse_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "逆転前の停止待機時間（ミリ秒）。接触器消弧のため",
          "default": 500,
          "example": 500
        },
        "cooldown_sec": {
          "type": "integer",
          "minimum": 0,
          "description": "動作後のクールダウン秒数",
          "default": 30,
          "example": 30
        }
      }
    },
    "trigger": {
      "type": "object",
      "description": "コマンド発行のトリガー情報（オプション）",
      "properties": {
        "event_type": {
          "type": "string",
          "example": "motor_state"
        },
        "temperature_c": {
          "type": "number",
          "description": "トリガーとなった温度（℃）",
          "example": 30.6
        }
      }
    }
  },
  "definitions": {
    "MotorCommand": {
      "oneOf": [
        {
          "type": "object",
          "description": "実行コマンド",
          "required": ["command"],
          "properties": {
            "command": {
              "type": "string",
              "enum": ["forward", "reverse", "stop"],
              "description": "forward=開、reverse=閉、stop=停止"
            },
            "target_direction": {
              "type": "string",
              "enum": ["forward", "reverse", "stopped"],
              "description": "目標動作方向"
            }
          }
        },
        {
          "type": "object",
          "description": "スキップ指示",
          "required": ["skip", "reason"],
          "properties": {
            "skip": {
              "type": "boolean",
              "enum": [true]
            },
            "reason": {
              "type": "string",
              "enum": ["override", "override_false", "already_at_target", "cooldown"],
              "description": "スキップ理由"
            }
          }
        }
      ]
    }
  }
}
