{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "event_mode_change.json",
  "title": "ModeChangeEvent",
  "description": "動作モード変更イベント",
  "type": "object",
  "required": ["device_id","event_type","mode","previous_mode","timestamp"],
  "properties": {
    "device_id":     { "type": "string", "example": "x320-curtain-01" },
    "event_type":    { "type": "string", "enum": ["mode_change"] },
    "mode":          { "type": "string", "enum": ["manual","auto"] },
    "previous_mode": { "type": "string", "enum": ["manual","auto"] },
    "timestamp":     { "type": "number", "description": "Unix epoch 秒" }
  }
}
