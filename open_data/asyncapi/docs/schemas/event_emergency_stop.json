{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "event_emergency_stop.json",
  "title": "EmergencyStopEvent",
  "description": "物理緊急停止ボタンの状態変化イベント。MQTT コマンドでの制御不可",
  "type": "object",
  "required": ["device_id","event_type","state","timestamp"],
  "properties": {
    "device_id":  { "type": "string", "example": "x320-curtain-01" },
    "event_type": { "type": "string", "enum": ["emergency_stop"] },
    "state":      { "type": "string", "enum": ["active","inactive"], "description": "active=ボタン押下中" },
    "timestamp":  { "type": "number", "description": "Unix epoch 秒" }
  }
}
