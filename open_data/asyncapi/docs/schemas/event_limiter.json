{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "event_limiter.json",
  "title": "LimiterEvent",
  "description": "リミッタースイッチの状態変化イベント",
  "type": "object",
  "required": ["device_id","event_type","motor_id","limiter","state","previous_state","timestamp"],
  "properties": {
    "device_id":      { "type": "string", "example": "x320-curtain-01" },
    "event_type":     { "type": "string", "enum": ["limiter"] },
    "motor_id":       { "type": "string", "enum": ["M1","M2"] },
    "limiter":        { "type": "string", "enum": ["upper","lower"], "description": "upper=上限、lower=下限" },
    "state":          { "type": "string", "enum": ["active","inactive"] },
    "previous_state": { "type": "string", "enum": ["active","inactive"] },
    "timestamp":      { "type": "number", "description": "Unix epoch 秒" }
  }
}
